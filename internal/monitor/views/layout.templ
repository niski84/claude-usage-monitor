package views

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="en" class="h-full dark">
		<head>
			<script>
				(function(){try{var s=localStorage.getItem('cmonitor-theme');document.documentElement.classList.toggle('dark',s!=='light');}catch(e){document.documentElement.classList.add('dark')}})();
			</script>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<meta name="color-scheme" content="dark light"/>
			<title>{ title } — Claude Usage</title>
			<link rel="stylesheet" href="/static/app.css"/>
			<script defer src="/static/alpine.min.js"></script>
		</head>
		<body class="bg-zinc-950 text-zinc-100 min-h-screen font-sans antialiased">
			<nav class="sticky top-0 z-50 bg-zinc-900/80 backdrop-blur border-b border-zinc-800">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="flex items-center justify-between h-14">
						<a href="/dashboard" class="flex items-center gap-2 font-semibold text-base text-zinc-100 hover:opacity-80 transition-opacity">
							<span class="text-violet-400">⚡</span>
							Claude Usage
						</a>
						<div class="flex items-center gap-3">
							<button
								type="button"
								x-data
								@click="fetch('/api/refresh',{method:'POST'}).then(()=>setTimeout(()=>location.reload(),800))"
								class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors px-2 py-1 rounded border border-zinc-700 hover:border-zinc-500"
								title="Force refresh stats now"
							>↻ Refresh</button>
							<button
								type="button"
								onclick="(function(){var d=document.documentElement.classList.toggle('dark');try{localStorage.setItem('cmonitor-theme',d?'dark':'light');}catch(e){}})()"
								class="p-2 rounded-lg text-zinc-500 hover:text-zinc-100 hover:bg-zinc-800 transition-colors"
							>
								<svg xmlns="http://www.w3.org/2000/svg" class="hidden dark:block h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
								<svg xmlns="http://www.w3.org/2000/svg" class="block dark:hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
							</button>
						</div>
					</div>
				</div>
			</nav>
			<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
				{ children... }
			</main>
			<script src="/static/htmx.min.js"></script>
		</body>
	</html>
}
